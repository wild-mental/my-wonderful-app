# DATA-001 — keep this file free of real secrets.
# Real values are injected via Vercel Environment Variables / Supabase Vault.

# --- Database (CON-9) ------------------------------------------------------
# Supabase Postgres pooled URL (used by app runtime).
DATABASE_URL="postgresql://user:password@host:5432/postgres?schema=public&pgbouncer=true&connection_limit=1"
# Direct (non-pooled) URL used by `prisma migrate` only.
DIRECT_URL="postgresql://user:password@host:5432/postgres?schema=public"

# --- App ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- LLM (Phase 2 placeholder, CON-11/12) ---------------------------------
# Reserved for Vercel AI SDK + Google Gemini. Runtime usage is forbidden in MVP.
GOOGLE_AI_API_KEY=""

# --- External APIs (forward-declared) -------------------------------------
COUPANG_PARTNERS_ACCESS_KEY=""
COUPANG_PARTNERS_SECRET_KEY=""
MFDS_OPEN_API_KEY=""
KAKAO_JS_KEY=""
RESEND_API_KEY=""

# --- Analytics ------------------------------------------------------------
NEXT_PUBLIC_MIXPANEL_TOKEN=""
NEXT_PUBLIC_AMPLITUDE_API_KEY=""
